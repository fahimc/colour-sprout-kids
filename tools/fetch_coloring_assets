def count_regions(mask):
    pixels = mask.getdata()
    counts = {}
    for px in pixels:
        if px[3] > 0:
            counts[px] = counts.get(px, 0) + 1
    return [{"id": i + 1, "maskColor": "#%02X%02X%02X" % c[:3], "pixelCount": count} for i, (c, count) in enumerate(counts.items())]


def main():
