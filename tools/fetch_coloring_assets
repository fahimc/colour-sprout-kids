        out.mkdir(parents=True, exist_ok=True)
        line, mask, thumb = page_scene(page_id, title)
        line.save(out / "line.png")
        mask.save(out / "mask.png")
        thumb.resize((384, 384), Image.Resampling.LANCZOS).save(out / "thumb.png")
        license_id = f"generated-{page_id}"
        metadata = {
            "id": page_id,
            "title": title,
            "category": category,
            "difficulty": difficulty,
            "tags": tags,
            "lineArtPath": f"coloring/{category}/{page_id}/line.png",
            "maskPath": f"coloring/{category}/{page_id}/mask.png",
            "thumbnailPath": f"coloring/{category}/{page_id}/thumb.png",
            "licenseId": license_id,
            "needs_manual_mask": False,
            "regions": count_regions(mask),
        }
        (out / "metadata.json").write_text(json.dumps(metadata, indent=2), encoding="utf-8")
        licenses.append({
            "id": license_id,
            "title": title,
            "source site": "Project-generated original asset",
            "original source link": "tools/fetch_coloring_assets",
            "author if available": "ColourSprout Kids generator",
            "license": "CC0-1.0 / public-domain dedication for generated starter art",
            "attribution required yes/no": "no",
            "local file path": f"app/src/main/assets/coloring/{category}/{page_id}/line.png",
            "date downloaded": str(date.today()),
        })
        accepted.append({"id": page_id, "category": category, "title": title, "regions": len(metadata["regions"])})
    LICENSE_FILE.write_text(json.dumps(licenses, indent=2), encoding="utf-8")
    REPORT_FILE.write_text(json.dumps({"accepted": accepted, "rejected": []}, indent=2), encoding="utf-8")
    print(f"Generated {len(accepted)} colouring pages in {ASSET_ROOT}")
    print(f"Wrote {LICENSE_FILE}")
    print(f"Wrote {REPORT_FILE}")


if __name__ == "__main__":
    main()
