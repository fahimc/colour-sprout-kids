def region_color(index):
    r = (37 * index + 50) % 220 + 25
    g = (73 * index + 80) % 220 + 25
    b = (109 * index + 120) % 220 + 25
    return (r, g, b, 255)


def pastel(index):
    r, g, b, _ = region_color(index)
    return (min(255, 110 + r // 2), min(255, 110 + g // 2), min(255, 110 + b // 2), 255)


def draw_shape(line, mask, thumb, kind, box, region, fill_thumb=True):
    outline = ImageDraw.Draw(line)
    regions = ImageDraw.Draw(mask)
    thumbs = ImageDraw.Draw(thumb)
    color = region_color(region)
    thumb_color = pastel(region)
    if kind == "ellipse":
        outline.ellipse(box, outline=(20, 20, 20, 255), width=LINE)
        regions.ellipse(shrink(box, LINE), fill=color)
        if fill_thumb:
            thumbs.ellipse(shrink(box, LINE), fill=thumb_color, outline=(20, 20, 20, 255), width=LINE)
    elif kind == "rect":
        outline.rounded_rectangle(box, radius=24, outline=(20, 20, 20, 255), width=LINE)
        regions.rounded_rectangle(shrink(box, LINE), radius=18, fill=color)
        if fill_thumb:
            thumbs.rounded_rectangle(shrink(box, LINE), radius=18, fill=thumb_color, outline=(20, 20, 20, 255), width=LINE)
    elif kind == "poly":
        outline.line(box + [box[0]], fill=(20, 20, 20, 255), width=LINE, joint="curve")
        regions.polygon(box, fill=color)
        if fill_thumb:
            thumbs.polygon(box, fill=thumb_color)
            thumbs.line(box + [box[0]], fill=(20, 20, 20, 255), width=LINE, joint="curve")


def shrink(box, amount):
    if isinstance(box[0], tuple):
        return box
    x0, y0, x1, y1 = box
    return (x0 + amount, y0 + amount, x1 - amount, y1 - amount)


def add_face(line, thumb, cx, cy, scale=1.0):
    d1 = ImageDraw.Draw(line)
    d2 = ImageDraw.Draw(thumb)
    for d in (d1, d2):
        w = max(4, int(6 * scale))
        d.ellipse((cx - 50 * scale, cy - 20 * scale, cx - 32 * scale, cy - 2 * scale), fill=(20, 20, 20, 255))
        d.ellipse((cx + 32 * scale, cy - 20 * scale, cx + 50 * scale, cy - 2 * scale), fill=(20, 20, 20, 255))
        d.arc((cx - 34 * scale, cy - 4 * scale, cx + 34 * scale, cy + 42 * scale), 15, 165, fill=(20, 20, 20, 255), width=w)


