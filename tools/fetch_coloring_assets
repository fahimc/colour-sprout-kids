def region_color(index: int):
    return ((37 * index + 50) % 220 + 25, (73 * index + 80) % 220 + 25, (109 * index + 120) % 220 + 25, 255)


def pastel(index: int):
    r, g, b, _ = region_color(index)
    return (min(255, 125 + r // 2), min(255, 125 + g // 2), min(255, 125 + b // 2), 255)


def crop_cell(sheet: Image.Image, index: int) -> Image.Image:
    w, h = sheet.size
    cell_w, cell_h = w // 4, h // 4
    col, row = index % 4, index // 4
    crop = sheet.crop((col * cell_w, row * cell_h, (col + 1) * cell_w, (row + 1) * cell_h)).convert("RGB")
    bg = Image.new("RGB", crop.size, "white")
    bg.paste(crop)
    gray = ImageOps.grayscale(bg)
    bbox = gray.point(lambda p: 255 if p < 175 else 0).filter(ImageFilter.MaxFilter(5)).getbbox()
    if bbox:
        pad = 18
        bbox = (max(0, bbox[0] - pad), max(0, bbox[1] - pad), min(crop.width, bbox[2] + pad), min(crop.height, bbox[3] + pad))
        crop = crop.crop(bbox)
    canvas = Image.new("RGB", (SIZE, SIZE), "white")
    max_side = SIZE - 44
    scale = min(max_side / crop.width, max_side / crop.height)
    crop = crop.resize((max(1, int(crop.width * scale)), max(1, int(crop.height * scale))), Image.Resampling.LANCZOS)
    canvas.paste(crop, ((SIZE - crop.width) // 2, (SIZE - crop.height) // 2))
    return canvas


def line_bitmap(cell: Image.Image) -> tuple[Image.Image, Image.Image]:
    gray = ImageOps.grayscale(cell)
    black = gray.point(lambda p: 255 if p < 190 else 0).filter(ImageFilter.MaxFilter(3))
    alpha = black.filter(ImageFilter.GaussianBlur(0.35))
    line = Image.new("RGBA", (SIZE, SIZE), (0, 0, 0, 0))
    line.putalpha(alpha)
    binary = black.point(lambda p: 1 if p > 0 else 0)
    return line, binary


def make_mask(binary_line: Image.Image) -> tuple[Image.Image, list[dict]]:
    width, height = binary_line.size
    line = binary_line.load()
    visited = bytearray(width * height)
    mask = Image.new("RGBA", (width, height), (0, 0, 0, 0))
    mask_px = mask.load()
    regions = []

    def idx(x, y): return y * width + x

    for start_y in range(height):
        for start_x in range(width):
            start_idx = idx(start_x, start_y)
            if visited[start_idx] or line[start_x, start_y]:
                continue
            q = deque([(start_x, start_y)])
            visited[start_idx] = 1
            pixels = []
            touches_border = False
            while q:
                x, y = q.popleft()
                pixels.append((x, y))
                if x <= 2 or y <= 2 or x >= width - 3 or y >= height - 3:
                    touches_border = True
                for nx, ny in ((x + 1, y), (x - 1, y), (x, y + 1), (x, y - 1)):
                    if 0 <= nx < width and 0 <= ny < height:
                        n = idx(nx, ny)
                        if not visited[n] and not line[nx, ny]:
                            visited[n] = 1
                            q.append((nx, ny))
            if touches_border or len(pixels) < MIN_REGION:
                continue
            region_id = len(regions) + 1
            color = region_color(region_id)
            for x, y in pixels:
                mask_px[x, y] = color
            xs = [p[0] for p in pixels]
            ys = [p[1] for p in pixels]
            regions.append({
                "id": region_id,
                "maskColor": "#%02X%02X%02X" % color[:3],
                "pixelCount": len(pixels),
                "bounds": [min(xs), min(ys), max(xs), max(ys)],
            })
    return mask, regions


def make_thumb(line: Image.Image, mask: Image.Image, regions: list[dict]) -> Image.Image:
    thumb = Image.new("RGBA", (SIZE, SIZE), (255, 250, 232, 255))
    px = mask.load()
    out = thumb.load()
    palette = {region["maskColor"]: pastel(region["id"]) for region in regions}
    for y in range(SIZE):
        for x in range(SIZE):
            r, g, b, a = px[x, y]
            if a:
                out[x, y] = palette.get("#%02X%02X%02X" % (r, g, b), (220, 230, 190, 255))
    thumb.alpha_composite(line)
    ImageDraw.Draw(thumb).rounded_rectangle((18, 18, SIZE - 18, SIZE - 18), radius=28, outline=(132, 94, 55, 255), width=6)
    return thumb.resize((384, 384), Image.Resampling.LANCZOS)


def main():
    sources = {p.name: Image.open(p).convert("RGB") for p in SOURCE_ROOT.glob("*.png")}
    if len(sources) < 2:
        raise SystemExit(f"Expected generated source sheets in {SOURCE_ROOT}")
    expected = {(category, page_id) for _, _, category, page_id, *_ in PAGES}
    if ASSET_ROOT.exists():
        for metadata_path in ASSET_ROOT.glob("*/*/metadata.json"):
            category = metadata_path.parent.parent.name
            page_id = metadata_path.parent.name
            if (category, page_id) not in expected:
                for child in metadata_path.parent.iterdir():
                    child.unlink()
                metadata_path.parent.rmdir()
    accepted, rejected, licenses = [], [], []
    for source_name, cell_index, category, page_id, title, difficulty, tags in PAGES:
        try:
            cell = crop_cell(sources[source_name], cell_index)
            line, binary = line_bitmap(cell)
            mask, regions = make_mask(binary)
            if not regions:
                raise ValueError("no fillable regions detected")
            out = ASSET_ROOT / category / page_id
            out.mkdir(parents=True, exist_ok=True)
            line.save(out / "line.png")
            mask.save(out / "mask.png")
            make_thumb(line, mask, regions).save(out / "thumb.png")
            license_id = f"ai-generated-{page_id}"
            metadata = {
                "id": page_id,
                "title": title,
                "category": category,
                "difficulty": difficulty,
                "tags": tags,
                "lineArtPath": f"coloring/{category}/{page_id}/line.png",
                "maskPath": f"coloring/{category}/{page_id}/mask.png",
                "thumbnailPath": f"coloring/{category}/{page_id}/thumb.png",
                "licenseId": license_id,
                "needs_manual_mask": False,
                "regions": regions,
            }
            (out / "metadata.json").write_text(json.dumps(metadata, indent=2), encoding="utf-8")
            licenses.append({
                "id": license_id,
                "title": title,
                "source site": "OpenAI image generation",
                "original source link": f"tools/generated_sources/{source_name} cell {cell_index}",
                "author if available": "Generated for ColourSprout Kids from project prompt",
                "license": "Project-owned generated asset; distributed with this app under the repository license",
                "attribution required yes/no": "no",
                "local file path": f"app/src/main/assets/coloring/{category}/{page_id}/line.png",
                "date downloaded": str(date.today()),
            })
            accepted.append({"id": page_id, "category": category, "title": title, "source": source_name, "cell": cell_index, "regions": len(regions)})
        except Exception as exc:
            rejected.append({"id": page_id, "source": source_name, "cell": cell_index, "reason": str(exc)})
    LICENSE_FILE.write_text(json.dumps(licenses, indent=2), encoding="utf-8")
    REPORT_FILE.write_text(json.dumps({"accepted": accepted, "rejected": rejected}, indent=2), encoding="utf-8")
    print(f"Generated {len(accepted)} assets from generated source sheets")
    print(f"Rejected {len(rejected)} assets")
    if rejected:
        print(json.dumps(rejected, indent=2))


if __name__ == "__main__":
    main()
